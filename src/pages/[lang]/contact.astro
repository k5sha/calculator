---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl } from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "uk" } }];
}

const lang = getLangFromUrl(Astro.url);

const pageT = {
  uk: {
    title: "Зворотний зв'язок",
    subtitle: "Технічна підтримка та пропозиції щодо розвитку лабораторії.",
    
    cardTitle: "📬 Зв'язатися з розробником",
    cardDesc: "Маєте питання щодо алгоритмів, знайшли помилку в розрахунках або хочете запропонувати новий функціонал? Пишіть нам на офіційну пошту проекту.",
    
    emailLabel: "Електронна пошта для запитів:",
    responseTitle: "⏳ Час відповіді",
    responseTime: "Зазвичай ми відповідаємо протягом 24-48 годин у робочі дні.",

    terminalHeader: "[*] MAIL_CLIENT_INIT",
    terminalLines: [
      "Establishing connection to SMTP...",
      "Target: zipzip.tech.help@gmail.com",
      "Status: Ready to receive messages",
      "Encryption: End-to-End active"
    ],
    footerNote: "Ваші дані не передаються третім особам і використовуються лише для відповіді на запит."
  },
  en: {
    title: "Contact Us",
    subtitle: "Technical support and suggestions for laboratory development.",
    
    cardTitle: "📬 Get in Touch",
    cardDesc: "Have questions about algorithms, found a calculation error, or want to suggest new features? Email us at our official project address.",
    
    emailLabel: "Email address for inquiries:",
    responseTitle: "⏳ Response Time",
    responseTime: "We usually respond within 24-48 hours on business days.",

    terminalHeader: "[*] MAIL_CLIENT_INIT",
    terminalLines: [
      "Establishing connection to SMTP...",
      "Target: zipzip.tech.help@gmail.com",
      "Status: Ready to receive messages",
      "Encryption: End-to-End active"
    ],
    footerNote: "Your data is not shared with third parties and is used only for responding to your inquiry."
  }
}[lang];
---

<Layout title={`${pageT.title} — Coding Theory Lab`}>
  <main class="main-content">
    <header class="hero">
      <h1>{pageT.title}</h1>
      <p class="description">{pageT.subtitle}</p>
    </header>

    <div class="grid-layout">
      <div class="info-side">
        <section class="contact-card">
          <h3>{pageT.cardTitle}</h3>
          <p>{pageT.cardDesc}</p>
          
          <div class="email-box">
            <span>{pageT.emailLabel}</span>
            <a href="mailto:zipzip.tech.help@gmail.com" class="email-link">
              zipzip.tech.help@gmail.com
            </a>
          </div>
        </section>

        <section class="theory-card" style="border-left-color: #f59e0b; background: #fffbeb;">
          <h3 style="color: #92400e;">{pageT.responseTitle}</h3>
          <p style="color: #78350f;">{pageT.responseTime}</p>
        </section>
      </div>

      <div class="terminal-side">
        <div class="terminal">
          <span class="highlight-blue">{pageT.terminalHeader}</span>
          <br /><br />
          {pageT.terminalLines.map(line => (
            <>
              <span class="highlight-green">>></span> {line}
              <br />
            </>
          ))}
          <br />
          <span class="blink">_</span>
        </div>
        
        <p class="footer-note">{pageT.footerNote}</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 20px;
  }
  .hero {
    text-align: center;
    margin-bottom: 50px;
  }
  h1 { color: var(--primary); font-size: 2.8rem; margin-bottom: 10px; }
  .description { font-size: 1.2rem; color: #64748b; }
  
  .grid-layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .grid-layout { grid-template-columns: 1fr; }
  }

  .contact-card {
    background: white;
    padding: 35px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-bottom: 30px;
  }
  .contact-card h3 { margin-bottom: 15px; color: #1e293b; }
  
  .email-box {
    margin-top: 25px;
    padding: 20px;
    background: #f1f5f9;
    border-radius: 12px;
  }
  .email-box span { display: block; font-size: 0.9rem; color: #64748b; margin-bottom: 5px; }
  .email-link {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--primary);
    text-decoration: none;
    word-break: break-all;
  }
  .email-link:hover { text-decoration: underline; }

  .theory-card {
    padding: 25px;
    border-radius: 15px;
    border-left: 6px solid;
  }

  .terminal {
    background: #0f172a;
    color: #e2e8f0;
    padding: 30px;
    border-radius: 20px;
    font-family: 'Fira Code', monospace;
    font-size: 0.85rem;
    border: 1px solid #1e293b;
    margin-bottom: 20px;
  }
  .highlight-blue { color: #38bdf8; font-weight: bold; }
  .highlight-green { color: #4ade80; }
  .blink { animation: blink 1s infinite; color: var(--primary); }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  
  .footer-note {
    font-size: 0.85rem;
    color: #94a3b8;
    text-align: center;
    padding: 0 20px;
  }
</style>