---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "uk" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allCodes = [
  {
    name: lang === "uk" ? "Рекурентний код" : "Recurrent Code",
    path: `/${lang}/codes/recurrent`,
    description:
      lang === "uk"
        ? "Потужний алгоритм кодування з використанням регістрів зсуву для виправлення пакетів помилок."
        : "A powerful coding algorithm using shift registers to correct error bursts.",
    category: t("category.error"),
    icon: "🔄",
    isAvailable: true,
  },
  {
    name: lang === "uk" ? "Коди-супутники" : "Companion Codes",
    path: `/${lang}/codes/companions`,
    description:
      lang === "uk"
        ? "Метод виправлення помилок за допомогою побудови таблиць супутніх векторів для кодових комбінацій."
        : "Error correction method using companion vector tables for code combinations.",
    category: t("category.systematic"),
    icon: "🛰️",
    isAvailable: true,
  },
  {
    name: lang === "uk" ? "Код Хеммінга" : "Hamming Code",
    path: "#",
    description:
      lang === "uk"
        ? "Класичний метод самокоригованих кодів для контролю цілісності даних."
        : "A classic error-correcting code method for data integrity control.",
    category: t("category.systematic"),
    icon: "🛡️",
    isAvailable: false,
  },
  {
    name: lang === "uk" ? "Код Хаффмена" : "Huffman Code",
    path: "#",
    description:
      lang === "uk"
        ? "Алгоритм оптимального префіксного кодування для стиснення без втрат."
        : "An optimal prefix coding algorithm for lossless data compression.",
    category: t("category.compression"),
    icon: "📦",
    isAvailable: false,
  },
  {
    name: lang === "uk" ? "Код Грея" : "Gray Code",
    path: "#",
    description:
      lang === "uk"
        ? "Мінімальна зміна бітів при переключенні станів. Ідеально для енкодерів."
        : "Minimal bit change between states. Ideal for rotary encoders.",
    category: t("category.transform"),
    icon: "🔢",
    isAvailable: false,
  },
];
---

<Layout title={t("hero.title")}>
  <div class="main-wrapper">
    <header class="hero-section">
      <h1>Coding Theory <span>Lab</span></h1>
      <p>{t("hero.subtitle")}</p>

      <div class="search-wrapper">
        <div class="search-box">
          <svg
            class="search-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            type="text"
            id="codeSearch"
            placeholder={t("search.placeholder")}
            autocomplete="off"
          />
          <kbd class="search-kbd">/</kbd>
        </div>
      </div>
    </header>

    <div class="grid-container">
      <div class="grid" id="codesGrid">
        {
          allCodes.map((code) => (
            <a
              href={code.isAvailable ? code.path : "#"}
              class={`glass-card ${!code.isAvailable ? "is-pending" : ""}`}
              data-name={code.name.toLowerCase()}
            >
              <div class="card-header">
                <span class="icon-box">{code.icon}</span>
                <span class={`tag ${!code.isAvailable ? "tag-dev" : ""}`}>
                  {code.isAvailable ? code.category : t("card.dev")}
                </span>
              </div>
              <div class="card-body">
                <h3>{code.name}</h3>
                <p>{code.description}</p>
              </div>
              <div class="card-arrow">
                <span>
                  {code.isAvailable ? t("card.available") : t("card.pending")}
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))
        }
      </div>

      <div id="noResults" class="empty-state" style="display: none;">
        <div class="empty-icon">🏜️</div>
        <h3>{t("search.noResults")}</h3>
        <p>{t("search.noResultsSub")}</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById("codeSearch") as HTMLInputElement;
  const cards = document.querySelectorAll(".glass-card");
  const noResults = document.getElementById("noResults");

  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
    }
  });

  searchInput?.addEventListener("input", (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase();
    let found = false;

    cards.forEach((card) => {
      const name = card.getAttribute("data-name") || "";
      const isVisible = name.includes(query);
      (card as HTMLElement).style.display = isVisible ? "flex" : "none";
      if (isVisible) found = true;
    });

    if (noResults) noResults.style.display = found ? "none" : "block";
  });
</script>

<style>
  /* Ваші стилі залишаються без змін */
  .main-wrapper {
    padding-bottom: 5rem;
  }
  .hero-section {
    text-align: center;
    padding: 3rem 1rem;
    max-width: 1620px;
    margin: 0 auto;
  }
  .hero-section h1 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    line-height: 1;
  }
  .hero-section h1 span {
    background: linear-gradient(135deg, #2563eb 0%, #60a5fa 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    display: inline-block;
  }
  .hero-section p {
    font-size: clamp(1.1rem, 4vw, 1.25rem);
    color: var(--text-light);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .search-wrapper {
    max-width: 550px;
    margin: 0 auto;
  }
  .search-box {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--text-light);
    opacity: 0.7;
  }
  #codeSearch {
    width: 100%;
    padding: 1.2rem 1.5rem 1.2rem 3.5rem;
    border-radius: 1.25rem;
    border: 1px solid var(--border);
    background: var(--card);
    font-family: inherit;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  #codeSearch:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
  }
  .search-kbd {
    position: absolute;
    right: 1.2rem;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text-light);
  }
  .grid-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .glass-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .is-pending {
    opacity: 0.7;
    cursor: default;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.5);
  }
  .glass-card:not(.is-pending):hover {
    transform: translateY(-5px);
    border-color: var(--primary);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.05);
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .icon-box {
    font-size: 2rem;
    background: var(--bg);
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.4rem 0.75rem;
    background: #f1f5f9;
    border-radius: 20px;
    color: var(--text-light);
  }
  .tag-dev {
    background: #fef3c7;
    color: #92400e;
  }
  .card-body h3 {
    font-size: 1.4rem;
    margin: 0 0 0.75rem;
    font-weight: 700;
  }
  .card-body p {
    color: var(--text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }
  .card-arrow {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .is-pending .card-arrow {
    color: var(--text-light);
  }
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
  }
  @media (max-width: 640px) {
    .search-kbd {
      display: none;
    }
  }
</style>
