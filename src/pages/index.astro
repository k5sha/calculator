---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Рекурентний код — Калькулятор">
  <main class="main-content">
    <header class="hero">
      <h1>Рекурентне кодування</h1>
      <p class="description">
        Інтерактивний інструмент для вивчення завадостійкого рекурентного коду з
        кроком додавання <strong>k</strong>.
      </p>
    </header>

    <section class="theory-card">
      <h3>📚 Про алгоритм</h3>
      <p>
        Рекурентний код — це метод кодування, де кожна перевірочна посилка
        залежить від поточного та попереднього інформаційного біта. Він належить
        до класу систематичних кодів.
      </p>
      <ul>
        <li>
          <strong>Принцип кодування:</strong> Формується послідовність перевірочних
          бітів за формулою:
          <code>b[i] = a[i] ⊕ a[i-k]</code>. Перші <code>k</code> бітів перевірочної
          послідовності дорівнюють нулю.
        </li>
        <li>
          <strong>Виправлення помилок:</strong> Алгоритм ефективно виправляє одиночні
          помилки в інформаційних бітах. Якщо стається помилка в біті <code
            >a[i]</code
          >, вона "відгукується" в синдромі на позиціях <code>i</code> та <code
            >i+k</code
          >.
        </li>
        <li>
          <strong>Синдром:</strong> Це результат XOR між прийнятими перевірочними
          бітами та тими, що згенеровані на основі прийнятого повідомлення.
        </li>
      </ul>
    </section>

    <div class="container">
      <h2>🔒 Кодування</h2>
      <div class="grid-layout">
        <div class="controls">
          <div class="input-group">
            <label>Інформаційне повідомлення (A):</label>
            <input type="text" id="encode_msg" value="001011100100001" />
          </div>
          <div class="input-group">
            <label>Крок k:</label>
            <input type="number" id="encode_k" value="4" />
          </div>
          <button id="btn_encode">Закодувати</button>
        </div>
        <div id="encode_log" class="terminal">
          // Натисніть "Закодувати", щоб побачити кроки...
        </div>
      </div>
    </div>

    <div class="container">
      <h2>🔓 Декодування та виправлення</h2>
      <div class="grid-layout">
        <div class="controls">
          <div class="input-group">
            <label>Прийняте повідомлення (A'):</label>
            <input type="text" id="decode_msg" value="000100111011101001" />
          </div>
          <div class="input-group">
            <label>Прийняті перевірочні (B'):</label>
            <input type="text" id="decode_check" value="000010100001000011" />
          </div>
          <div class="input-group">
            <label>Крок k:</label>
            <input type="number" id="decode_k" value="4" />
          </div>
          <button id="btn_decode">Виправити помилки</button>
        </div>
        <div id="decode_log" class="terminal">
          // Очікування даних для аналізу...
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .hero {
    text-align: center;
    margin-bottom: 40px;
  }
  h1 {
    color: var(--primary);
    font-size: 2.8rem;
    margin-bottom: 10px;
  }
  .description {
    font-size: 1.2rem;
    color: #64748b;
  }

  .theory-card {
    background: #eff6ff;
    padding: 25px;
    border-radius: 12px;
    border-left: 6px solid var(--primary);
    margin-bottom: 40px;
  }
  .theory-card h3 {
    margin-top: 0;
    color: #1e40af;
  }
  .theory-card code {
    background: #dbeafe;
    padding: 2px 5px;
    border-radius: 4px;
    font-weight: bold;
  }

  .container {
    background: var(--card);
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin-bottom: 40px;
  }
  .grid-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 30px;
  }
  @media (max-width: 900px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
  }

  .input-group {
    margin-bottom: 20px;
  }
  label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
    color: #475569;
  }
  input {
    width: 100%;
    padding: 12px;
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    font-family: "Courier New", monospace;
    font-size: 1rem;
    box-sizing: border-box;
  }
  input:focus {
    border-color: var(--primary);
    outline: none;
  }

  button {
    width: 100%;
    background: var(--primary);
    color: white;
    border: none;
    padding: 15px;
    border-radius: 10px;
    font-weight: bold;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  button:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
  }
  button:active {
    transform: translateY(0);
  }

  .terminal {
    background: var(--terminal-bg);
    color: var(--terminal-text);
    padding: 20px;
    border-radius: 12px;
    font-family: "Fira Code", "Consolas", monospace;
    font-size: 0.9rem;
    min-height: 250px;
    white-space: pre-wrap;
    overflow-x: auto;
    border: 1px solid #333;
  }
</style>

<script>
  const getVal = (id: string) =>
    (document.getElementById(id) as HTMLInputElement).value;
  const writeLog = (id: string, html: string) => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = html;
  };

  // --- КОДУВАННЯ ---
  document.getElementById("btn_encode")?.addEventListener("click", () => {
    const msg = getVal("encode_msg").replace(/\s/g, "");
    const k = parseInt(getVal("encode_k"));
    if (!/^[01]+$/.test(msg))
      return alert("Помилка: Використовуйте лише 0 та 1");

    let a = msg.split("").map(Number);
    let b = new Array(a.length).fill(0);
    let log = `<span class="highlight-blue">[*] ПОЧАТОК КОДУВАННЯ (k=${k})</span>\n`;

    for (let i = k; i < a.length; i++) {
      b[i] = a[i] ^ a[i - k];
      log += `Крок ${i}: a[${i}](${a[i]}) ⊕ a[${i - k}](${a[i - k]}) = ${b[i]}\n`;
    }

    log += `\n<span class="highlight-green">[УСПІХ] Згенерована послідовність B:</span>\n${b.join("")}`;
    writeLog("encode_log", log);
  });

  // --- ДЕКОДУВАННЯ ---
  document.getElementById("btn_decode")?.addEventListener("click", () => {
    const a_in = getVal("decode_msg").replace(/\s/g, "");
    const b_in = getVal("decode_check").replace(/\s/g, "");
    const k = parseInt(getVal("decode_k"));

    if (a_in.length !== b_in.length)
      return alert("Довжини A та B повинні бути однаковими!");

    let a = a_in.split("").map(Number);
    let b_rec = b_in.split("").map(Number);
    let n = a.length;

    let log = `<span class="highlight-blue">[*] АНАЛІЗ ПРИЙНЯТОГО ПОВІДОМЛЕННЯ</span>\n`;

    // 1. Контрольні біти
    let b_ctrl = new Array(n).fill(0);
    for (let i = k; i < n; i++) b_ctrl[i] = a[i] ^ a[i - k];

    // 2. Синдром
    let diff = b_ctrl.map((val, i) => val ^ b_rec[i]);
    log += `Контрольні біти:  ${b_ctrl.join("")}\n`;
    log += `Прийняті біти:    ${b_rec.join("")}\n`;
    log += `Синдром помилки:  <span class="highlight-red">${diff.join("")}</span>\n\n`;

    // 3. Виправлення
    let a_corr = [...a];
    let fixCount = 0;
    for (let i = 0; i < n - k; i++) {
      if (diff[i] === 1 && diff[i + k] === 1) {
        log += `<span class="highlight-red">[!]</span> Помилка в біті a[${i}]. Інвертуємо...\n`;
        a_corr[i] = 1 - a_corr[i];
        diff[i] = 0;
        diff[i + k] = 0;
        fixCount++;
      }
    }

    log += `\n<span class="highlight-green">[*] РЕЗУЛЬТАТ:</span>\n`;
    log += `Початкове A:  ${a_in}\n`;
    log += `Виправлене A: ${a_corr.join("")}\n`;
    log += `Кількість виправлень: ${fixCount}`;

    writeLog("decode_log", log);
  });
</script>
