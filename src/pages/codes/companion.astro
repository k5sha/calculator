---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Коди-супутники — Калькулятор">
  <main class="main-content">
    <header class="hero">
      <h1>Коди-супутники (Компаньйони)</h1>
      <p class="description">
        Інтерактивний інструмент для побудови кодової таблиці та виправлення помилок за допомогою кодів-супутників.
      </p>
    </header>

    <section class="theory-card">
      <h3>📚 Про алгоритм</h3>
      <p>
        Коди-супутники, також відомі як коди-компаньйони, є надлишковими кодами, які додаються до основного інформаційного коду для виявлення та виправлення помилок[cite: 2]. Вони "супроводжують" основний код, звідси й назва[cite: 3].
      </p>
      <ul>
        <li>
          <strong>Побудова таблиці:</strong> У першому рядку розташовується вихідна кодова комбінація[cite: 9]. У наступних рядках записують вектори, які отримують в результаті сумування за модулем 2 вихідної комбінації з векторами помилок вагою <em>w=1</em> (одна помилка), потім <em>w=2</em> (дві помилки) і так далі[cite: 10, 11, 13].
        </li>
        <li>
          <strong>Декодування:</strong> У разі прийому комбінації, що збігається з одним із кодів-супутників, спотворена комбінація розшифровується як вихідна робоча комбінація, до якої входить даний код-супутник[cite: 7, 15, 45].
        </li>
        <li>
          <strong>Недоліки:</strong> Основними недоліками даного методу є високі вимоги до пам'яті для зберігання кодової таблиці та значні часові витрати на перебір комбінацій під час декодування[cite: 16, 46, 47].
        </li>
      </ul>
    </section>

    <div class="container">
      <h2>📋 Побудова кодової таблиці</h2>
      <div class="grid-layout">
        <div class="controls">
          <div class="input-group">
            <label>Вихідна комбінація (V):</label>
            <input type="text" id="gen_msg" value="101101" />
          </div>
          <div class="input-group">
            <label>Кратність помилок (w):</label>
            <select id="gen_w" style="width: 100%; padding: 12px; border: 2px solid #e2e8f0; border-radius: 10px; font-size: 1rem;">
              <option value="1">w = 1 (Одиночні помилки)</option>
              <option value="2">w = 2 (Подвійні помилки)</option>
            </select>
          </div>
          <button id="btn_generate">Згенерувати супутники</button>
        </div>
        <div id="gen_log" class="terminal">
          // Натисніть "Згенерувати супутники", щоб побудувати таблицю...
        </div>
      </div>
    </div>

    <div class="container">
      <h2>🔓 Декодування повідомлення</h2>
      <div class="grid-layout">
        <div class="controls">
          <div class="input-group">
            <label>Очікувана вихідна комбінація (V):</label>
            <input type="text" id="decode_orig" value="101101" />
          </div>
          <div class="input-group">
            <label>Прийнята комбінація (V'):</label>
            <input type="text" id="decode_msg" value="111101" />
          </div>
          <div class="input-group">
            <label>Макс. виправних помилок (w):</label>
            <input type="number" id="decode_w" value="1" min="1" max="3" />
          </div>
          <button id="btn_decode">Декодувати</button>
        </div>
        <div id="decode_log" class="terminal">
          // Очікування даних для аналізу...
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .hero {
    text-align: center;
    margin-bottom: 40px;
  }
  h1 {
    color: var(--primary);
    font-size: 2.8rem;
    margin-bottom: 10px;
  }
  .description {
    font-size: 1.2rem;
    color: #64748b;
  }

  .theory-card {
    background: #eff6ff;
    padding: 25px;
    border-radius: 12px;
    border-left: 6px solid var(--primary);
    margin-bottom: 40px;
  }
  .theory-card h3 {
    margin-top: 0;
    color: #1e40af;
  }
  .theory-card em {
    background: #dbeafe;
    padding: 2px 5px;
    border-radius: 4px;
    font-weight: bold;
    font-style: normal;
  }

  .container {
    background: var(--card);
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    margin-bottom: 40px;
  }
  .grid-layout {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 30px;
  }
  @media (max-width: 900px) {
    .grid-layout {
      grid-template-columns: 1fr;
    }
  }

  .input-group {
    margin-bottom: 20px;
  }
  label {
    display: block;
    margin-bottom: 8px;
    font-weight: bold;
    color: #475569;
  }
  input {
    width: 100%;
    padding: 12px;
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    font-family: "Courier New", monospace;
    font-size: 1rem;
    box-sizing: border-box;
  }
  input:focus, select:focus {
    border-color: var(--primary);
    outline: none;
  }

  button {
    width: 100%;
    background: var(--primary);
    color: white;
    border: none;
    padding: 15px;
    border-radius: 10px;
    font-weight: bold;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  button:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
  }
  button:active {
    transform: translateY(0);
  }

  .terminal {
    background: var(--terminal-bg);
    color: var(--terminal-text);
    padding: 20px;
    border-radius: 12px;
    font-family: "Fira Code", "Consolas", monospace;
    font-size: 0.9rem;
    min-height: 250px;
    white-space: pre-wrap;
    overflow-x: auto;
    border: 1px solid #333;
  }
</style>

<script>
  const getVal = (id: string) => (document.getElementById(id) as HTMLInputElement).value;
  const writeLog = (id: string, html: string) => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = html;
  };

  // Функція для пошуку всіх комбінацій позицій (для інвертування бітів)
  function getCombinations(arr: number[], k: number): number[][] {
    let result: number[][] = [];
    function combine(start: number, path: number[]) {
      if (path.length === k) {
        result.push([...path]);
        return;
      }
      for (let i = start; i < arr.length; i++) {
        path.push(arr[i]);
        combine(i + 1, path);
        path.pop();
      }
    }
    combine(0, []);
    return result;
  }

  // Функція для генерації кодів-супутників заданої ваги
  function generateCompanions(msgStr: string, w: number) {
    const n = msgStr.length;
    const indices = Array.from({ length: n }, (_, i) => i);
    const combos = getCombinations(indices, w);
    
    return combos.map(combo => {
      let arr = msgStr.split('');
      combo.forEach(idx => {
        arr[idx] = arr[idx] === '0' ? '1' : '0'; // Сумування за mod2 (інверсія)
      });
      // Формування вектора помилки для візуалізації
      let errorVector = new Array(n).fill('0');
      combo.forEach(idx => errorVector[idx] = '1');
      
      return { code: arr.join(''), errorVector: errorVector.join(''), flipped: combo };
    });
  }

  // --- ПОБУДОВА ТАБЛИЦІ ---
  document.getElementById("btn_generate")?.addEventListener("click", () => {
    const msg = getVal("gen_msg").replace(/\s/g, "");
    const w = parseInt(getVal("gen_w"));
    
    if (!/^[01]+$/.test(msg)) return alert("Помилка: Використовуйте лише 0 та 1");

    let log = `<span class="highlight-blue">[*] ПОБУДОВА КОДІВ-СУПУТНИКІВ (w=${w})</span>\n\n`;
    log += `Вихідна комбінація: <span class="highlight-green">${msg}</span>\n\n`;

    const companions = generateCompanions(msg, w);
    
    log += `Знайдено комбінацій: ${companions.length}\n`;
    log += `----------------------------------------\n`;
    log += `Супутник | Вектор помилки (e)\n`;
    log += `----------------------------------------\n`;
    
    companions.forEach(comp => {
      log += `${comp.code} | ${comp.errorVector}\n`;
    });

    writeLog("gen_log", log);
  });

  // --- ДЕКОДУВАННЯ ---
  document.getElementById("btn_decode")?.addEventListener("click", () => {
    const orig_in = getVal("decode_orig").replace(/\s/g, "");
    const rec_in = getVal("decode_msg").replace(/\s/g, "");
    const max_w = parseInt(getVal("decode_w"));

    if (orig_in.length !== rec_in.length) return alert("Довжини вихідної та прийнятої комбінацій повинні збігатися!");
    if (!/^[01]+$/.test(orig_in) || !/^[01]+$/.test(rec_in)) return alert("Використовуйте лише 0 та 1");

    let log = `<span class="highlight-blue">[*] АНАЛІЗ ПРИЙНЯТОГО ПОВІДОМЛЕННЯ</span>\n\n`;
    log += `Очікуваний код: ${orig_in}\n`;
    log += `Прийнятий код:  ${rec_in}\n\n`;

    if (orig_in === rec_in) {
      log += `<span class="highlight-green">[УСПІХ] Комбінація прийнята без спотворень!</span>\n`;
      return writeLog("decode_log", log);
    }

    log += `Помилка виявлена. Пошук у таблиці кодів-супутників...\n\n`;

    let found = false;
    // Шукаємо збіг серед кодів-супутників для кожної ваги помилки від 1 до max_w
    for (let current_w = 1; current_w <= max_w; current_w++) {
      const companions = generateCompanions(orig_in, current_w);
      const match = companions.find(c => c.code === rec_in);
      
      if (match) {
        log += `[!] Збіг знайдено у списку супутників з w=${current_w}.\n`;
        log += `Вектор помилки: <span class="highlight-red">${match.errorVector}</span>\n\n`;
        log += `<span class="highlight-green">[*] РЕЗУЛЬТАТ ДЕКОДУВАННЯ:</span>\n`;
        log += `Комбінація розшифровується як вихідна: <span class="highlight-green">${orig_in}</span>`;
        found = true;
        break;
      }
    }

    if (!found) {
      log += `<span class="highlight-red">[ПОМИЛКА] Прийняту комбінацію не знайдено серед кодів-супутників до w=${max_w}.</span>\n`;
      log += `Декодування неможливе. Перевищено кратність виправних помилок.`;
    }

    writeLog("decode_log", log);
  });
</script>