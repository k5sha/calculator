---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Рекурентне кодування онлайн" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-wrapper">
      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          Made with ❤️ by
          <a
            href="https://github.com/k5sha"
            target="_blank"
            rel="noopener noreferrer"
          >
            k5sha
          </a>
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #1e293b;
    --terminal-bg: #1e1e1e;
    --terminal-text: #d4d4d4;
    --footer-text: #64748b;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg);
    color: var(--text);
    font-family: "Segoe UI", system-ui, sans-serif;
  }

  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 1;
  }

  /* Стилі футера */
  .site-footer {
    padding: 2.5rem 1rem;
    text-align: center;
    background-color: var(--card);
    border-top: 1px solid #e2e8f0;
    color: var(--footer-text);
    font-size: 1rem;
  }

  .site-footer p {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .site-footer a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
    transition: color 0.2s ease;
    border-bottom: 2px solid transparent;
  }

  .site-footer a:hover {
    color: var(--primary-hover);
    border-bottom: 2px solid var(--primary-hover);
  }

  /* Глобальні класи для логів */
  .highlight-green {
    color: #4ade80;
    font-weight: bold;
  }
  .highlight-red {
    color: #f87171;
    font-weight: bold;
  }
  .highlight-blue {
    color: #60a5fa;
    font-weight: bold;
  }
</style>
