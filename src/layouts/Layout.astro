---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  keywords: string;
  description: string;
}

const { title, keywords, description } = Astro.props;

const siteBase = Astro.site || "https://calculator.k5sha.xyz";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navT = {
  uk: {
    home: "Головна",
    about: "Про проєкт",
    contact: "Контакти",
    privacy: "Приватність",
  },
  en: { home: "Home", about: "About", contact: "Contact", privacy: "Privacy" },
}[lang];

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://calculator.k5sha.xyz",
);

const alternateLang = lang === "en" ? "uk" : "en";
const alternatePath = Astro.url.pathname.replace(
  `/${lang}/`,
  `/${alternateLang}/`,
);
const alternateURL = new URL(
  alternatePath,
  Astro.site || "https://calculator.k5sha.xyz",
);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Coding Theory Lab</title>
    <meta name="title" content={`${title} | Coding Theory Lab`} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="k5sha" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="en" href={new URL("/en/", siteBase).href} />
    <link rel="alternate" hreflang="uk" href={new URL("/uk/", siteBase).href} />
    <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL("/en/", siteBase).href}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Coding Theory Lab`} />
    <meta property="og:description" content={t("hero.subtitle")} />
    <meta property="og:image" content="/og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2563eb" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Coding Theory Lab",
        "applicationCategory": "EducationalApplication",
        "operatingSystem": "All",
        "author": {
          "@type": "Person",
          "name": "k5sha",
          "url": "https://github.com/k5sha"
        },
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
      }
    </script>

    <script
      is:inline
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-8H72EK4TMJ"></script>

    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-8H72EK4TMJ");
    </script>
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-container">
        <a href={`/${lang}/`} class="nav-logo">
          <img
            src="/favicon.ico"
            alt="Logo"
            class="logo-img"
            width="48"
            height="48"
          />
          <span class="logo-text">Coding Theory <span>Lab</span></span>
        </a>
        <div class="nav-links">
          <a href={`/${lang}/`} class="nav-link home">
            {lang === "uk" ? "Головна" : "Home"}
          </a>

          <div class="lang-picker">
            <a
              href={alternatePath}
              class="lang-chip"
              title={lang === "en"
                ? "Змінити мову на Українську"
                : "Change language to English"}
            >
              <span class="flag-icon">
                {
                  lang === "en" ? (
                    <svg viewBox="0 0 640 480" width="16" height="12">
                      <>
                        <rect width="640" height="480" fill="#ffd700" />
                        <rect width="640" height="240" fill="#0057b8" />
                      </>
                    </svg>
                  ) : (
                    <svg viewBox="0 0 640 480" width="16" height="12">
                      <>
                        <path fill="#bd3d44" d="M0 0h640v480H0z" />
                        <path
                          stroke="#fff"
                          stroke-width="37"
                          d="M0 55h640M0 129h640M0 203h640M0 277h640M0 351h640M0 425h640"
                        />
                        <path fill="#192f5d" d="M0 0h365v258H0z" />
                        <circle fill="#fff" cx="46" cy="35" r="12" />
                        <circle fill="#fff" cx="116" cy="35" r="12" />
                        <circle fill="#fff" cx="186" cy="35" r="12" />
                      </>
                    </svg>
                  )
                }
              </span>
              <span class="lang-label">
                {lang === "en" ? "UA" : "EN"}
              </span>
            </a>
          </div>

          <a
            href="https://github.com/k5sha/calculator"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link github"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
              ></path>
            </svg>
            <span>GitHub</span>
          </a>
        </div>
      </div>
    </nav>

    <div class="page-wrapper">
      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-content">
          <nav class="footer-nav">
            <a href={`/${lang}/about/`} class="footer-link">{navT.about}</a>
            <span class="footer-dot">•</span>
            <a href={`/${lang}/contact/`} class="footer-link">{navT.contact}</a>
            <span class="footer-dot">•</span>
            <a href={`/${lang}/privacy`} class="footer-link">{navT.privacy}</a>
          </nav>

          <p class="developed-by">
            {lang === "uk" ? "Розроблено з" : "Developed with"}
            <span class="heart">❤️</span>
            {lang === "uk" ? "від" : "by"}
            <a
              href="https://github.com/k5sha"
              target="_blank"
              rel="noopener noreferrer">k5sha</a
            >
          </p>
          <div class="footer-divider"></div>
          <p class="copyright">
            &copy; {new Date().getFullYear()} Coding Theory Lab. All rights reserved.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #0f172a;
    --terminal-bg: #1e1e1e;
    --terminal-text: #d4d4d4;
    --text-light: #64748b;
    --border: rgba(226, 232, 240, 0.8);
    --nav-bg: rgba(255, 255, 255, 0.85);
    --font-main: "Plus Jakarta Sans", system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background-color: var(--bg);
    color: var(--text);
    font-family: var(--font-main);
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 65px);
  }
  main {
    flex: 1;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  .nav-logo:hover .logo-img {
    transform: scale(1.1) rotate(-5deg);
  }
  .logo-text {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
  }
  .logo-text span {
    color: var(--primary);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nav-link {
    text-decoration: none;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 700;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nav-link:hover {
    color: var(--primary);
  }

  .lang-picker {
    display: flex;
    align-items: center;
    margin-left: 0.25rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
  }

  .lang-chip {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(37, 99, 235, 0.05);
    border: 1px solid rgba(37, 99, 235, 0.15);
    border-radius: 100px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .lang-chip:hover {
    background: #ffffff;
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.12);
    transform: translateY(-1px);
  }

  .flag-icon {
    display: flex;
    align-items: center;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.15);
  }

  .lang-label {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--text-light);
    line-height: 1;
    transition: color 0.2s ease;
  }

  .lang-chip:hover .lang-label {
    color: var(--primary);
  }

  .nav-link.github {
    background: var(--text);
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-size: 0.85rem;
  }
  .nav-link.github:hover {
    background: #000;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
    color: white;
  }

  .site-footer {
    padding: 3rem 1rem 2rem;
    background-color: var(--card);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .footer-link {
    text-decoration: none;
    color: var(--text-light);
    font-size: 0.9rem;
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--primary);
  }
  .footer-dot {
    color: var(--border);
    font-size: 0.8rem;
  }

  .developed-by {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .site-footer a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 700;
  }
  .footer-divider {
    width: 40px;
    height: 1px;
    background: #e2e8f0;
  }
  .copyright {
    margin: 0;
    font-size: 0.75rem !important;
    color: var(--text-light);
    opacity: 0.8;
  }
  .heart {
    color: #ef4444;
  }

  .terminal .highlight-blue {
    color: #60a5fa;
    font-weight: bold;
  }
  .terminal .highlight-green {
    color: #4ade80;
    font-weight: bold;
  }
  .terminal .highlight-red {
    color: #f87171;
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 0.75rem;
    }
    .lang-picker {
      padding-left: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .logo-text {
      font-size: 1.1rem;
    }
    .home {
      display: none;
    }
    
    .nav-link > span:not(.lang-label) {
      display: none;
    }
    .nav-container {
      padding: 0.75rem 1rem;
    }
    .lang-picker {
      border-left: none;
      padding-left: 0;
      margin-left: 0;
    }
    .lang-chip {
      padding: 6px;
      border-radius: 8px;
    }
    .lang-label {
      display: none;
    }
    .nav-link.github {
      padding: 0.5rem;
      border-radius: 8px;
    }
  }
</style>
