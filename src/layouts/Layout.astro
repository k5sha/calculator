---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Рекурентне кодування онлайн" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --bg: #f8fafc;
    --card: #ffffff;
    --text: #1e293b;
    --terminal-bg: #1e1e1e;
    --terminal-text: #d4d4d4;
  }
  html,
  body {
    margin: 0;
    padding: 0;
    background-color: var(--bg);
    color: var(--text);
    font-family: "Segoe UI", system-ui, sans-serif;
  }
  /* Глобальні класи для логів (щоб працювали з JS) */
  .highlight-green {
    color: #4ade80;
    font-weight: bold;
  }
  .highlight-red {
    color: #f87171;
    font-weight: bold;
  }
  .highlight-blue {
    color: #60a5fa;
    font-weight: bold;
  }
</style>
